{
  "schemaVersion": 1,
  "version": "2026-05-29.1",
  "apps": [
    {
      "id": "bridge-mira",
      "name": "Mira",
      "description": {
        "en": "Fertility Tracker",
        "fr": "Tracker de fertilité"
      },
      "icon": {
        "type": "base64",
        "value": "data:image/png;base64,"
      },
      "category": "medical",
      "provider": "Quanovate Inc.",
      "hook": {
        "initiate": {
          "method": "POST",
          "url": "https://bridge-mira.datasafe.dev/mira/initiate",
          "auth": "ApiEndpoint ${apiEndpoint}",
          "body": {
            "returnUrl": "${returnUrl}"
          },
          "openUrlField": "openUrl"
        },
        "open": {
          "url": "${openUrl}",
          "embed": false
        },
        "resync": {
          "initiate": {
            "method": "POST",
            "url": "https://bridge-mira.datasafe.dev/mira/resync",
            "auth": "ApiEndpoint ${apiEndpoint}",
            "body": {
              "returnUrl": "${returnUrl}"
            },
            "openUrlField": "openUrl"
          },
          "url": "${openUrl}",
          "embed": false
        },
        "disconnect": {
          "method": "POST",
          "url": "https://bridge-mira.datasafe.dev/mira/revoke",
          "auth": "ApiEndpoint ${apiEndpoint}"
        }
      },
      "lastSync": {
        "type": "api",
        "url": "https://bridge-mira.datasafe.dev/mira/lastSync",
        "auth": "ApiEndpoint ${apiEndpoint}",
        "field": "lastSyncedAt",
        "needsReauthField": "needsReauth"
      }
    },
    {
      "id": "bridge-cyclefeminin",
      "name": "cyclefeminin",
      "description": {
        "en": "Import your cyclefeminin cycle history into HDS",
        "fr": "Importez votre historique de cycle cyclefeminin dans HDS"
      },
      "consentMessage": {
        "en": "The cyclefeminin importer will read your exported cyclefeminin JSON file in your browser and write the cycle, fertility and body-sign events into your HDS account. Nothing is uploaded anywhere else.",
        "fr": "L'importateur cyclefeminin lit le fichier JSON exporté depuis cyclefeminin dans votre navigateur et écrit les événements de cycle, de fertilité et de signes corporels dans votre compte HDS. Rien n'est envoyé ailleurs."
      },
      "icon": {
        "type": "url",
        "value": "https://cyclefeminin.net/img/logo.png"
      },
      "category": "health",
      "provider": "cyclefeminin.net",
      "actionButton": {
        "label": {
          "en": "Upload new data",
          "fr": "Importer de nouvelles données"
        }
      },
      "permissions": [
        { "streamId": "cyclefeminin-custom", "defaultName": "Cyclefeminin (imported)", "level": "manage" },
        { "streamId": "cyclefeminin-custom-mucus-notes", "defaultName": "mucus notes", "level": "manage" },
        { "streamId": "cyclefeminin-custom-day-comments", "defaultName": "day comments", "level": "manage" },
        { "streamId": "cyclefeminin-custom-cycle-comments", "defaultName": "cycle comments", "level": "manage" },
        { "streamId": "cyclefeminin-custom-cycle-method", "defaultName": "cycle method", "level": "manage" },
        { "streamId": "cyclefeminin-custom-cycle-temperature-context", "defaultName": "cycle temperature context", "level": "manage" },
        { "streamId": "body-temperature-basal", "defaultName": "body-temperature-basal", "level": "manage" },
        { "streamId": "body-vulva-bleeding", "defaultName": "body-vulva-bleeding", "level": "manage" },
        { "streamId": "body-vulva-mucus-inspect", "defaultName": "body-vulva-mucus-inspect", "level": "manage" },
        { "streamId": "fertility-cycles-start", "defaultName": "fertility-cycles-start", "level": "manage" },
        { "streamId": "fertility-cycles-peak-day", "defaultName": "fertility-cycles-peak-day", "level": "manage" },
        { "streamId": "fertility-cycles-fertile-window", "defaultName": "fertility-cycles-fertile-window", "level": "manage" },
        { "streamId": "fertility-ttc-tta", "defaultName": "fertility-ttc-tta", "level": "manage" },
        { "streamId": "fertility-sexual-activity", "defaultName": "fertility-sexual-activity", "level": "manage" },
        { "streamId": "symptom-gastrointestinal-cramps", "defaultName": "symptom-gastrointestinal-cramps", "level": "manage" },
        { "streamId": "symptom-sleep-insomnia", "defaultName": "symptom-sleep-insomnia", "level": "manage" }
      ],
      "hook": {
        "open": {
          "url": "https://demo-bridge-cycles-files.datasafe.dev/cyclefem",
          "embed": true,
          "params": {
            "apiEndpoint": "${apiEndpoint}",
            "return": "${returnUrl}"
          }
        }
      },
      "lastSync": {
        "type": "pryv-stream",
        "streamId": ".bridge-cyclefeminin.imports"
      }
    },
    {
      "id": "bridge-femm",
      "name": "FEMM",
      "description": {
        "en": "Import your FEMM Health cycle history into HDS",
        "fr": "Importez votre historique de cycle FEMM dans HDS"
      },
      "consentMessage": {
        "en": "The FEMM importer reads your exported FEMM JSON file in your browser and writes cycle, fertility, symptom and medication events into your HDS account. Subsequent uploads update or remove events that have changed in the source file (incremental sync). Nothing is uploaded anywhere else.",
        "fr": "L'importateur FEMM lit votre fichier JSON exporté depuis FEMM dans votre navigateur et écrit les événements de cycle, fertilité, symptômes et médicaments dans votre compte HDS. Les imports suivants mettent à jour ou suppriment les événements modifiés dans le fichier source (synchronisation incrémentale). Rien n'est envoyé ailleurs."
      },
      "icon": {
        "type": "base64",
        "value": "data:image/jpeg;base64,"
      },
      "category": "health",
      "provider": "FEMM Health",
      "actionButton": {
        "label": {
          "en": "Sync new FEMM data",
          "fr": "Synchroniser les nouvelles données FEMM"
        }
      },
      "permissions": [
        { "streamId": "bridge-femm", "defaultName": "FEMM", "level": "manage" },
        { "streamId": "bridge-femm-raw-converted", "defaultName": "FEMM raw", "level": "manage" },
        { "streamId": "bridge-femm-app", "defaultName": "FEMM app", "level": "manage" },
        { "streamId": "bridge-femm-app-notes", "defaultName": "FEMM notes", "level": "manage" },
        { "streamId": "body-vulva-bleeding", "defaultName": "Bleeding", "level": "manage" },
        { "streamId": "body-vulva-menstrual-cup", "defaultName": "Menstrual cup", "level": "manage" },
        { "streamId": "body-vulva-mucus-inspect", "defaultName": "Cervical fluid", "level": "manage" },
        { "streamId": "body-temperature-basal", "defaultName": "Basal body temperature", "level": "manage" },
        { "streamId": "fertility-cycles-start", "defaultName": "Cycle start", "level": "manage" },
        { "streamId": "fertility-sexual-activity", "defaultName": "Sexual activity", "level": "manage" },
        { "streamId": "fertility-test-opk", "defaultName": "Ovulation test (OPK)", "level": "manage" },
        { "streamId": "fertility-test-pregnancy", "defaultName": "Pregnancy test", "level": "manage" },
        { "streamId": "body-skin-acne", "defaultName": "Acne", "level": "manage" },
        { "streamId": "symptom-gastrointestinal-bloating", "defaultName": "Bloating", "level": "manage" },
        { "streamId": "symptom-pain-sore-breasts", "defaultName": "Sore breasts", "level": "manage" },
        { "streamId": "symptom-gastrointestinal-constipation", "defaultName": "Constipation", "level": "manage" },
        { "streamId": "symptom-gastrointestinal-cramps", "defaultName": "Cramps", "level": "manage" },
        { "streamId": "symptom-gastrointestinal-cravings", "defaultName": "Food cravings", "level": "manage" },
        { "streamId": "symptom-gastrointestinal-diarrhea", "defaultName": "Diarrhea", "level": "manage" },
        { "streamId": "symptom-neurological-dizziness", "defaultName": "Dizziness", "level": "manage" },
        { "streamId": "symptom-general-fatigue", "defaultName": "Fatigue", "level": "manage" },
        { "streamId": "symptom-pain-headache", "defaultName": "Headache", "level": "manage" },
        { "streamId": "symptom-pain-muscle", "defaultName": "Muscle / joint pain", "level": "manage" },
        { "streamId": "symptom-gastrointestinal-nausea", "defaultName": "Nausea", "level": "manage" },
        { "streamId": "wellbeing-mood", "defaultName": "Mood", "level": "manage" },
        { "streamId": "symptom-cognitive-focus-difficulty", "defaultName": "Difficulty concentrating", "level": "manage" },
        { "streamId": "symptom-sleep-insomnia", "defaultName": "Insomnia", "level": "manage" },
        { "streamId": "medication-intake", "defaultName": "Medication intake", "level": "manage" },
        { "streamId": "fertility-cycles-average-length", "defaultName": "Average cycle length", "level": "manage" },
        { "streamId": "fertility-cycles-average-period", "defaultName": "Average period length", "level": "manage" }
      ],
      "hook": {
        "open": {
          "url": "https://demo-bridge-cycles-files.datasafe.dev/femm",
          "embed": true,
          "params": {
            "apiEndpoint": "${apiEndpoint}",
            "return": "${returnUrl}"
          }
        }
      },
      "lastSync": {
        "type": "pryv-stream",
        "streamId": "bridge-femm"
      }
    }
  ]
}
